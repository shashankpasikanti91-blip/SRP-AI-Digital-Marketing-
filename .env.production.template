# ── SRP Marketing OS — Production Environment (Hetzner) ──────────────────────
# COPY this to .env and fill in your values. NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=srp
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=srp_marketing
DATABASE_URL=postgresql+asyncpg://srp:CHANGE_ME_strong_password_here@db:5432/srp_marketing

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379/0

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# ── App ───────────────────────────────────────────────────────────────────────
 APP_NAME=SRP Marketing OS
ENVIRONMENT=production
DEBUG=false
ALLOWED_HOSTS=app.srpailabs.com
ALLOWED_ORIGINS=https://app.srpailabs.com
CORS_ORIGINS=https://app.srpailabs.com
APP_URL=https://app.srpailabs.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@yourdomain.com

# ── Hetzner Deployment ────────────────────────────────────────────────────────
# Server: Ubuntu 22.04 LTS, min 4GB RAM (CX21+ recommended)
# Run:  docker compose up -d --build
# Seed: Get-Content backend/seed_demo.sql | docker exec -i <db_container> psql -U srp -d srp_marketing
# SSL:  Use certbot + nginx or Cloudflare proxy
