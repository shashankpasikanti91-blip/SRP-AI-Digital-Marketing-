# ═══════════════════════════════════════════════════════════════════════════════
# SRP Marketing OS — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32_here
PROJECT_NAME=SRP Marketing OS
VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
POSTGRES_USER=srp
POSTGRES_PASSWORD=srp_secret_change_me
POSTGRES_DB=srp_marketing
DATABASE_URL=postgresql+asyncpg://srp:srp_secret_change_me@localhost:5432/srp_marketing

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me
REDIS_URL=redis://:redis_secret_change_me@localhost:6379/0

# ── JWT Auth ───────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Providers ───────────────────────────────────────────────────────────────
# Model format: "openai:gpt-4o" | "anthropic:claude-3-5-sonnet-latest" | "openai:gpt-4-turbo"
AI_MODEL=openai:gpt-4o
OPENAI_API_KEY=sk-proj-...your-openai-key...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# ── Email / SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SRP Marketing OS
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_TLS=true
SMTP_SSL=false

# ── Facebook ───────────────────────────────────────────────────────────────────
# Get these from: https://developers.facebook.com/apps/
FACEBOOK_ACCESS_TOKEN=EAAxxxx...your-page-access-token
FACEBOOK_PAGE_ID=123456789012345

# ── Instagram ───────────────────────────────────────────────────────────────────
# Instagram Business Account connected to Facebook Page
# Get from: https://developers.facebook.com/apps/ → Instagram Basic Display
INSTAGRAM_ACCESS_TOKEN=IGQVJxxxx...your-instagram-token
INSTAGRAM_ACCOUNT_ID=17841400000000000

# ── LinkedIn ───────────────────────────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps/
# Required permissions: w_organization_social, r_organization_social
LINKEDIN_ACCESS_TOKEN=AQXxxxx...your-linkedin-token
LINKEDIN_ORG_ID=12345678

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secret_change_me@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret_change_me@localhost:6379/1

# ── AI Model Routing ───────────────────────────────────────────────────────────
# REQUIRED for campaign generation, translation, and content AI features.
#
# Priority order (set both for best reliability + cost):
#   • OPENAI_API_KEY   → used as PRIMARY for translation/localization (most reliable)
#   • OPENROUTER_API_KEY → used as PRIMARY for content/design/analytics (cheapest)
#
# Sign up:
#   OpenAI:    https://platform.openai.com/api-keys
#   OpenRouter: https://openrouter.ai → Dashboard → API Keys
#
# Cost guidance (per 1M tokens):
#   GPT-4o-mini (OpenAI direct):       ~$0.15 input / $0.60 output
#   Gemini Flash 1.5 (via OpenRouter): ~$0.075 input / $0.30 output
#   GPT-4o (via OpenRouter):           ~$5.00 input / $15.00 output
#
# IMPORTANT: If OpenRouter key is invalid/expired, the system automatically
# falls back to OpenAI direct for translation. Set OPENAI_API_KEY always.

OPENAI_API_KEY=sk-proj-...your-openai-key...
OPENROUTER_API_KEY=sk-or-v1-...your-openrouter-key...

# Preferred provider for non-translation features: "openrouter" | "openai"
AI_PREFERRED_PROVIDER=openrouter

# AI generation limits (applied to all model calls)
AI_MAX_TOKENS=2500
AI_TEMPERATURE=0.75

# Public URL of your app (sent as HTTP-Referer to OpenRouter for rate-limit tier)
APP_URL=https://app.srpmarketingos.com

# ── Multilingual / Localization ─────────────────────────────────────────────────
# Supported languages (set as secondary_language in campaign builder):
#   Indian:  telugu, hindi, tamil, kannada, malayalam, bengali, marathi,
#            gujarati, punjabi, odia
#   SE Asia: malay, indonesian, thai, chinese_simplified
#
# Translation uses GPT-4o-mini direct (most accurate for Indian scripts).
# No extra config needed — language is chosen per campaign by the user.

# ── Supported Markets ──────────────────────────────────────────────────────────
# Industries pre-configured: healthcare, hospital, realestate, education,
#   retail, restaurant, automotive, fitness, legal, finance, technology,
#   dental, optical, beauty, recruitment, logistics, insurance, events, hotel
# Countries/regions: IN (India), AU, NZ, MY, SG, ID, TH

# ── AI Image Generation (cost control) ────────────────────────────────────────
# Set to false to disable AI image generation entirely (saves cost).
# When false, the system uses template-based poster JSON instead — no extra charge.
IMAGE_GENERATION_ENABLED=false
IMAGE_GENERATION_PREMIUM_ONLY=true  # If enabled, only Pro/Agency/Enterprise can use it

# ── AI Usage Tracking ─────────────────────────────────────────────────────────
# Tracks per-tenant token usage, estimated cost, and billing category.
# Powers the /api/v1/creatives/usage dashboard and plan enforcement.
USAGE_TRACKING_ENABLED=true
# "all" → log every call | "errors_only" → only failed calls | "disabled" → off
USAGE_TRACKING_LOG_LEVEL=all
